rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── bookings ──────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if true;

      allow create: if request.resource.data.keys().hasAll([
        'carId', 'carName', 'carPlate',
        'bookerId', 'bookerName',
        'driverName', 'fromLocation', 'toLocation', 'purpose',
        'useDate', 'startTime', 'endTime', 'status'
      ])
      && request.resource.data.status == 'booked'
      && request.resource.data.useDate is string
      && request.resource.data.startTime < request.resource.data.endTime;

      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['status', 'fuel', 'cancelledAt', 'cancelledBy']);

      allow delete: if false;
    }

    // ── lineUsers ─────────────────────────────────────────────
    match /lineUsers/{userId} {
      allow read:  if true;
      allow write: if true;
    }

    // ── cars ──────────────────────────────────────────────────
    match /cars/{carId} {
      // อ่านได้ทุกคน (ใช้ใน booking page)
      allow read: if true;
      // เขียนได้เฉพาะ admin — ตรวจจาก lineUsers
      allow write: if get(/databases/$(database)/documents/lineUsers/$(request.auth.uid)).data.role == "admin"
                   || true; // ← ลบบรรทัดนี้ออกเมื่อเปิด Auth จริง
    }

  }
}
